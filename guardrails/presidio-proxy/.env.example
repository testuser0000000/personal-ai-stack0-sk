# Copy to `.env` next to this file, or rely on env vars from the parent
# project's `.env`. Both work — config.py reads from process env.

# Request-side mode — what the proxy does with PII in the OUTBOUND prompt.
# REDACT  — replace PII with placeholders ([EMAIL], [PHONE], …) and pass through
# WARN    — log + pass original through unchanged
# BLOCK   — refuse with 400 + JSON explaining what was caught
PRESIDIO_MODE=REDACT

# Response-side mode — what the proxy does with PII in the INBOUND completion.
# Closes the leak path where an upstream model (e.g. a vision model reading
# an uploaded receipt) echoes PII back into the conversation.
# REDACT  — strip PII from the response stream / body before the client sees it
# WARN    — log finding metadata, but emit the original response unchanged
# OFF     — disable response scanning entirely (matches v0.1 behavior)
# BLOCK is intentionally absent: we may have already flushed tokens to the
# client by the time PII appears mid-stream, so "refuse" isn't a real option.
PRESIDIO_RESPONSE_MODE=REDACT

# Where the proxy listens.
PRESIDIO_PROXY_PORT=8000

# Where the proxy forwards (typically OpenRouter, but any OpenAI-compatible
# endpoint works). Strip the trailing slash.
PRESIDIO_UPSTREAM_URL=https://openrouter.ai/api/v1

# Bearer token for the upstream. The proxy strips any Authorization header
# from the incoming request and substitutes this — that way OpenWebUI never
# needs to know the real OpenRouter key, and the proxy can be the only thing
# that sees it.
OPENROUTER_API_KEY=sk-or-v1-replace-me

# Entity types to detect. Comma-separated. See redactor.py for the full
# list of supported types. Defaults are the high-signal technical leak
# vectors (emails, phones, credit cards, IPs, API keys).
# PERSON / LOCATION / ORG are intentionally OFF by default — those over-
# trigger on ordinary prose and are usually not what you mean by "PII".
PRESIDIO_ENTITIES=EMAIL_ADDRESS,PHONE_NUMBER,CREDIT_CARD,IP_ADDRESS,API_KEY

# Minimum confidence score (0.0–1.0) for a detection to act on it.
PRESIDIO_SCORE_THRESHOLD=0.4
