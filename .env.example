# Copy this file to `.env` and fill in real values.
# `.env` is gitignored; never commit it.

# ---------------------------------------------------------------
# OpenRouter — cloud LLM gateway (free + paid models from many vendors)
# Sign up: https://openrouter.ai/  — free tier available
# Format: sk-or-v1-...
# ---------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-v1-replace-me

# ---------------------------------------------------------------
# (Optional) Anthropic API direct — useful if you want to use Claude
# via the OpenWebUI in addition to your claude.ai subscription.
# Get a key at: https://console.anthropic.com/
# Format: sk-ant-...
# ---------------------------------------------------------------
# ANTHROPIC_API_KEY=sk-ant-replace-me

# ---------------------------------------------------------------
# (Optional) Groq — fast inference for free-tier open-source models,
# great for speech-to-text (Whisper).
# Get a key at: https://console.groq.com/  — free tier available
# Format: gsk_...
# ---------------------------------------------------------------
# GROQ_API_KEY=gsk_replace-me

# ---------------------------------------------------------------
# OpenWebUI server config
# ---------------------------------------------------------------
# Generate WEBUI_SECRET_KEY once and keep it stable across restarts:
#   head -c 32 /dev/urandom | base64
WEBUI_SECRET_KEY=replace-me-with-random-base64
WEBUI_PORT=3000

# ---------------------------------------------------------------
# Presidio PII-redaction proxy
# REDACT  — replace PII with placeholders ([EMAIL], [PHONE], ...) and pass through (default)
# WARN    — log + pass original through unchanged
# BLOCK   — refuse the request with a 400 explaining what was caught
# ---------------------------------------------------------------
PRESIDIO_MODE=REDACT
PRESIDIO_PROXY_PORT=8000
PRESIDIO_UPSTREAM_URL=https://openrouter.ai/api/v1

# ---------------------------------------------------------------
# Ollama (local model server) — defaults are usually fine
# ---------------------------------------------------------------
OLLAMA_HOST=127.0.0.1:11434
OLLAMA_MODELS=~/.local/share/ollama/models
